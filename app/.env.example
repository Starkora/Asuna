APP_NAME=
APP_ENV=production
APP_PORT=8000
APP_DEBUG=false
DEFAULT_APP_ID=farmacia

# Modo simple (una sola app)
ERP_API_KEY=

# Modo multi-app (recomendado): app_id:api_key separados por coma
# ERP_API_KEYS=farmacia:claveFarmacia,gimnasio:claveGym,rrhh:claveRRHH
ERP_API_KEYS=

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v22.0

REQUEST_TIMEOUT_SECONDS=20
SQLITE_PATH=./notifications.db
